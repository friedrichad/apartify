<Window x:Class="Apartify.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Apartify"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="Apartify System" FontSize="24" FontWeight="bold" Foreground="#2C3E50"></TextBlock>
            <Label Content="User Name"/>
            <TextBox x:Name="txtUsername" Height="30" VerticalContentAlignment="Center"/>
            <Label Content="Mật khẩu:"/>
            <PasswordBox x:Name="txtPassword" Height="30" Margin="0,0,0,20" VerticalContentAlignment="Center"/>
            <Button x:Name="btnLogin" Content="Đăng Nhập" Height="40" 
                    Background="#3498DB" Foreground="White" FontWeight="Bold"
                    Click="btnLogin_Click"/>
            <TextBlock x:Name="lblError" Foreground="Red" Margin="0,10,0,0" TextAlignment="Center"/>
            <TextBlock Text="No account yet? Register" 
               Foreground="Blue" TextDecorations="Underline" 
               Cursor="Hand" TextAlignment="Center"
               MouseLeftButtonUp="Register_Click"/>
        </StackPanel>

    </Grid>
</Window>
