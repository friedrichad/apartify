<Window x:Class="Apartify.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Apartify"
        mc:Ignorable="d"
        Title="Resident Register Account" Height="500" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Register Resident Account" FontSize="28" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,30" HorizontalAlignment="Center" Grid.Row="0"/>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Account Info -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Register" FontSize="18" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,15"/>
                
                <Label Content="User Name:"/>
                <TextBox x:Name="txtUsername" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,10"/>
                
                <Label Content="Password:"/>
                <PasswordBox x:Name="txtPassword" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,10"/>
                
                <Label Content="Confirm Password:"/>
                <PasswordBox x:Name="txtConfirmPassword" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="Role Selection" FontSize="16" FontWeight="SemiBold" Foreground="#34495E" Margin="0,15,0,5"/>
                <UniformGrid Columns="2" Margin="0,5,0,10">
                    <CheckBox x:Name="chkResident" Content="Resident" IsChecked="True" VerticalAlignment="Center"/>
                    <CheckBox x:Name="chkManager" Content="Manager" VerticalAlignment="Center"/>
                </UniformGrid>
            </StackPanel>
            
            <Separator Grid.Column="1" HorizontalAlignment="Center" Width="1" Background="#ECF0F1">
                <Separator.LayoutTransform>
                    <RotateTransform Angle="90"/>
                </Separator.LayoutTransform>
            </Separator>
            
            <!-- Resident Info -->
            <StackPanel Grid.Column="2" IsEnabled="{Binding IsChecked, ElementName=chkResident}">
                <TextBlock Text="Information" FontSize="18" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,15"/>
                
                <Label Content="Full Name:"/>
                <TextBox x:Name="txtFullName" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,10"/>
                
                <Label Content="Phone Number:"/>
                <TextBox x:Name="txtPhone" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,10"/>
                
                <Label Content="Email:"/>
                <TextBox x:Name="txtEmail" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,10"/>
            </StackPanel>
        </Grid>

        <TextBlock x:Name="lblStatus" Foreground="Red" Grid.Row="2" HorizontalAlignment="Center" Margin="0,10,0,10" TextAlignment="Center" TextWrapping="Wrap"/>
        
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="btnRegister" Content="Register" Width="150" Height="45" 
                    Background="#27AE60" Foreground="White" FontWeight="Bold" FontSize="16"
                    Click="btnRegister_Click" Margin="10,0"/>
            
            <Button x:Name="btnCancel" Content="Cancel" Width="150" Height="45" 
                    Background="#E74C3C" Foreground="White" FontWeight="Bold" FontSize="16"
                    Click="btnCancel_Click" Margin="10,0"/>
        </StackPanel>
    </Grid>
</Window>
