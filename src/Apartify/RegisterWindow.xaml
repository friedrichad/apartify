<Window x:Class="Apartify.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Apartify"
        mc:Ignorable="d"
        Title="Register Account" Height="600" Width="800" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="350">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Register" FontSize="28" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20" HorizontalAlignment="Center" Grid.Row="0"/>
        
        <StackPanel Grid.Row="1">
            <Label Content="User Name:" FontSize="14" Foreground="#34495E"/>
            <TextBox x:Name="txtUsername" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,10" Background="#FDFEFE"/>
            
            <Label Content="Password:" FontSize="14" Foreground="#34495E"/>
            <PasswordBox x:Name="txtPassword" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,10" Background="#FDFEFE"/>
            
            <Label Content="Confirm Password:" FontSize="14" Foreground="#34495E"/>
            <PasswordBox x:Name="txtConfirmPassword" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,10" Background="#FDFEFE"/>

            <TextBlock Text="Select Role:" FontSize="16" FontWeight="SemiBold" Foreground="#34495E" Margin="0,15,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                <RadioButton x:Name="rbManager" Content="Manager" Margin="0,0,20,0" VerticalAlignment="Center" FontSize="14" IsChecked="True" GroupName="RoleGroup"/>
                <RadioButton x:Name="rbStaff" Content="Staff" VerticalAlignment="Center" FontSize="14" GroupName="RoleGroup"/>
            </StackPanel>
        </StackPanel>

        <TextBlock x:Name="lblStatus" Foreground="Red" Grid.Row="2" HorizontalAlignment="Center" Margin="0,10,0,10" TextAlignment="Center" TextWrapping="Wrap"/>
        
        <StackPanel Grid.Row="3" Orientation="Vertical" HorizontalAlignment="Stretch" Margin="0,10,0,0">
            <Button x:Name="btnRegister" Content="Register" Height="45" 
                    Background="#27AE60" Foreground="White" FontWeight="Bold" FontSize="16"
                    Click="btnRegister_Click" Margin="0,0,0,10"/>
            
            <Button x:Name="btnCancel" Content="Cancel" Height="35" 
                    Background="Transparent" BorderBrush="#E74C3C" BorderThickness="1" Foreground="#E74C3C" FontWeight="Bold" FontSize="14"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
