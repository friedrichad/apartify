<Window x:Class="Apartify.Views.manager.CreateResident"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Apartify.Views.manager"
        mc:Ignorable="d"
        Title="CreateResident" Height="500" Width="300" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="0,0,1,0" Padding="10">
            <StackPanel>
                <TextBlock Text="RESIDENT REGISTRATION" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

                <Label Content="Full Name:"/>
                <TextBox x:Name="txtFullName" Padding="0,5,0,5" Margin="0,0,0,10"/>

                <Label Content="Phone:"/>
                <TextBox x:Name="txtPhone" Padding="0,5,0,5" Margin="0,0,0,10"/>

                <Label Content="Email:"/>
                <TextBox x:Name="txtEmail" Padding="0,5,0,5" Margin="0,0,0,10"/>
                <Label Content="User Name:"/>
                <TextBox x:Name="txtUserName" Padding="0,5,0,5" Margin="0,0,0,10"/>
                <Label Content="Password:"/>
                <TextBox x:Name="txtPassword" Padding="0,5,0,5" Margin="0,0,0,10"/>

                <UniformGrid Columns="1" Margin="0,10,0,0">
                    <Button Content="Save Change" Click="EditCommand" Margin="5" Height="30" Background="#3498DB" Foreground="White" FontWeight="SemiBold"/>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
