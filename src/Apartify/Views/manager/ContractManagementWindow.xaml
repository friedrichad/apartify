<Window x:Class="Apartify.Views.manager.ContractManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contract Management" Height="500" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderThickness="0,0,1,0" Padding="10">
            <StackPanel>
                <TextBlock Text="CONTRACT DETAIL" HorizontalAlignment="Center" FontSize="16" Margin="0,0,0,20"/>
                
                <Label Content="Start Date:"/>
                <DatePicker x:Name="dpStartDate" Margin="0,0,0,10"/>

                <Label Content="End Date:"/>
                <DatePicker x:Name="dpEndDate" Margin="0,0,0,20"/>

                <UniformGrid Columns="2">
                    <Button Content="Save Edit" Click="EditCommand" Margin="5" Height="30" Background="#3498DB" Foreground="White" FontWeight="SemiBold"/>
                    <Button Content="Delete" Click="DeleteCommand" Margin="5" Height="30" Background="#E74C3C" Foreground="White" FontWeight="SemiBold"/>
                    <Button Content="Close" Click="CloseCommand" Margin="5" Height="30" Grid.ColumnSpan="2" Background="#95A5A6" Foreground="White" FontWeight="SemiBold"/>
                </UniformGrid>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="10,0,0,0">
            <DataGrid x:Name="dgContract" 
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="DgContract_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Contract ID" Binding="{Binding ContractId}" Width="100"/>
                    <DataGridTextColumn Header="Resident" Binding="{Binding Resident.FullName}" Width="150"/>
                    <DataGridTextColumn Header="Apartment" Binding="{Binding Apartment.Number}" Width="100"/>
                    <DataGridTextColumn Header="Start Date" Binding="{Binding StartDate}" Width="120"/>
                    <DataGridTextColumn Header="End Date" Binding="{Binding EndDate}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
