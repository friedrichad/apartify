<Window x:Class="Apartify.Views.manager.CreateContractWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Contract" Height="400" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="CREATE CONTRACT" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

            <Label Content="Resident:"/>
            <TextBlock x:Name="txtResidentName" Padding="5" Margin="0,0,0,10" FontWeight="Bold"/>

            <Label Content="Apartment:"/>
            <ComboBox x:Name="cboApartment" Margin="0,0,0,10" DisplayMemberPath="Number" SelectedValuePath="ApartmentId"/>

            <Label Content="Start Date:"/>
            <DatePicker x:Name="dpStartDate" Margin="0,0,0,10"/>

            <Label Content="End Date:"/>
            <DatePicker x:Name="dpEndDate" Margin="0,0,0,20"/>

            <UniformGrid Columns="2">
                <Button Content="Save" Click="SaveCommand" Margin="5" Height="30" Background="#3498DB" Foreground="White" FontWeight="SemiBold"/>
                <Button Content="Cancel" Click="CancelCommand" Margin="5" Height="30" Background="#95A5A6" Foreground="White" FontWeight="SemiBold"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>
