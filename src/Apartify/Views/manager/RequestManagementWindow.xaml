<Window x:Class="Apartify.Views.manager.RequestManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Request View" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="RESIDENT REQUESTS" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <DataGrid Grid.Row="1" x:Name="dgRequest" 
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="DgRequest_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding RequestId}" Width="50"/>
                <DataGridTextColumn Header="Resident" Binding="{Binding Resident.FullName}" Width="150"/>
                <DataGridTextColumn Header="Apartment" Binding="{Binding Apartment.Number}" Width="100"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Date" Binding="{Binding RequestDate, StringFormat=dd/MM/yyyy HH:mm}" Width="120"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="Approve" Click="ApproveCommand" Width="100" Height="30" Margin="0,0,10,0" Background="#2ECC71" Foreground="White" FontWeight="Bold"/>
            <Button Content="Close" Click="CloseCommand" Width="100" Height="30" Background="#95A5A6" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

    </Grid>
</Window>
