<Window x:Class="Apartify.Views.manager.BuildingManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Apartify.Views.manager"
        mc:Ignorable="d"
        Title="BuildingManagementWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel quản lý chi tiết -->
        <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="0,0,1,0" Padding="10">
            <StackPanel>
                <TextBlock Text="BUILDING MANAGEMENT" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

                <Label Content="Name:"/>
                <TextBox x:Name="txtName" Padding="0,5,0,5"/>

                <Label Content="Address:"/>
                <TextBox x:Name="txtAddress" Padding="0,5,0,5"/>

                <UniformGrid Columns="2" Margin="0,10,0,0">
                    <Button Content="Add" Click="AddCommand" Margin="5" Height="30"/>
                    <Button Content="Save Change" Click="EditCommand" Margin="5" Height="30" Background="LightBlue"/>
                    <Button Content="Delete" Click="DeleteCommand" Margin="5" Height="30" Background="#e74c3c" Foreground="White"/>
                    <Button Content="Close" Click="CloseCommand" Margin="5" Height="30"/>
                </UniformGrid>

                <Separator Margin="0,20,0,10"/>
                <TextBlock Text="NAVIGATION" HorizontalAlignment="Center" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                <Button Content="Apartment Management" Click="NavApartment_Click" Margin="5" Height="35" Background="#3498db" Foreground="White"/>
                <Button Content="Resident Management" Click="NavResident_Click" Margin="5" Height="35" Background="#3498db" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- DataGrid hiển thị list -->
        <Grid Grid.Column="1" Margin="10,0,0,0">
            <DataGrid x:Name="dgBuilding" 
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="DgBuilding_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Building Id" Binding="{Binding BuildingId}" Width="80"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
