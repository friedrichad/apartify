<Window x:Class="Apartify.Views.manager.UserAccountManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account Management" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="USER ACCOUNT MANAGEMENT" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <DataGrid Grid.Row="1" x:Name="dgAccounts" 
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="DgAccounts_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="User ID" Binding="{Binding UserId}" Width="80"/>
                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="150"/>
                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="Deactivate" Click="DeactivateCommand" Width="120" Height="30" Margin="0,0,10,0" Background="#E74C3C" Foreground="White" FontWeight="Bold"/>
            <Button Content="Activate" Click="ActivateCommand" Width="120" Height="30" Margin="0,0,10,0" Background="#2ECC71" Foreground="White" FontWeight="Bold"/>
            <Button Content="Close" Click="CloseCommand" Width="100" Height="30" Background="#95A5A6" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
