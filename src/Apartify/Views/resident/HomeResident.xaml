<Window x:Class="Apartify.Views.resident.HomeResident"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Resident Home" Height="600" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Background="#F4F7F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#27AE60" Padding="20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Apartify" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <Separator Width="2" Margin="15,0" Background="#2ECC71"/>
                <TextBlock Text="Resident Portal" FontSize="18" Foreground="#ECF0F1" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        
        <!-- Main Content -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Welcome Home!" FontSize="32" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10" HorizontalAlignment="Center"/>
            <TextBlock Text="Everything about your apartment in one place." FontSize="18" Foreground="#7F8C8D" Margin="0,0,0,30" HorizontalAlignment="Center"/>
            
            <WrapPanel HorizontalAlignment="Center">
                <Button Content="My Profile" Width="180" Height="80" Margin="8" Background="#2980B9" Foreground="White" Click="Profile_Click"/>
                <Button Content="Apartment Info" Width="180" Height="80" Margin="8" Background="#8E44AD" Foreground="White" FontSize="14" FontWeight="SemiBold" Click="ApartmentInfo_Click"/>
                <Button Content="Contract" Width="180" Height="80" Margin="8" Background="#2C3E50" Foreground="White" FontSize="14" FontWeight="SemiBold" Click="Contract_Click"/>
                <Button Content="Service Request" Width="180" Height="80" Margin="8" Background="#E67E22" Foreground="White" FontSize="14" FontWeight="SemiBold" Click="Maintenance_Click"/>
            </WrapPanel>
        </StackPanel>
    </Grid>
</Window>
