<Window x:Class="Apartify.Views.resident.RequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Service Requests"
        Height="450" Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CREATE -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBox x:Name="tbDescription"
                     Width="400"
                     Height="30"
                     Margin="0,0,10,0"
                     VerticalContentAlignment="Center"/>

            <Button Content="Create Request"
                    Width="120"
                    Background="#27AE60"
                    Foreground="White"
                    Click="CreateRequest_Click"/>
        </StackPanel>

        <!-- LIST -->
        <ListView x:Name="lvRequests" Grid.Row="1">
            <ListView.View>
                <GridView>

                    <GridViewColumn Header="Date"
                                    Width="120"
                                    DisplayMemberBinding="{Binding RequestDate, StringFormat=dd/MM/yyyy}" />

                    <!-- FIX: ApartmentNumber -->
                    <GridViewColumn Header="Apartment"
                                    Width="120"
                                    DisplayMemberBinding="{Binding ApartmentNumber}" />

                    <GridViewColumn Header="Description"
                                    Width="250"
                                    DisplayMemberBinding="{Binding Description}" />

                    <GridViewColumn Header="Status"
                                    Width="100"
                                    DisplayMemberBinding="{Binding Status}" />

                </GridView>
            </ListView.View>
        </ListView>

        <!-- CLOSE -->
        <Button Grid.Row="2"
                Content="Close"
                Width="100"
                HorizontalAlignment="Right"
                Margin="0,10,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>