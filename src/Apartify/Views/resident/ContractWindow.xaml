<Window x:Class="Apartify.Views.resident.ContractWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contract Management"
        Height="400" Width="700">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="My Contracts"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- ListView -->
        <ListView x:Name="lvContracts" Grid.Row="1">
            <ListView.View>
                <GridView>

                    <GridViewColumn Header="Contract ID"
                            DisplayMemberBinding="{Binding ContractId}"
                            Width="100"/>

                    <!-- SỬA: ApartmentId → ApartmentNumber -->
                    <GridViewColumn Header="Apartment"
                            DisplayMemberBinding="{Binding ApartmentNumber}"
                            Width="120"/>

                    <!-- THÊM: Building -->
                    <GridViewColumn Header="Building"
                            DisplayMemberBinding="{Binding BuildingName}"
                            Width="150"/>

                    <!-- FORMAT DATE -->
                    <GridViewColumn Header="Start Date"
                            DisplayMemberBinding="{Binding StartDate, StringFormat=dd/MM/yyyy}"
                            Width="120"/>

                    <GridViewColumn Header="End Date"
                            DisplayMemberBinding="{Binding EndDate, StringFormat=dd/MM/yyyy}"
                            Width="120"/>

                </GridView>
            </ListView.View>
        </ListView>

        <!-- Close Button -->
        <Button Content="Close"
                Grid.Row="2"
                Width="100"
                HorizontalAlignment="Right"
                Margin="0,10,0,0"
                Click="Close_Click"/>

    </Grid>
</Window>