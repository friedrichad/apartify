<Window x:Class="Apartify.Views.ApartmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Apartify.Views"
        mc:Ignorable="d"
        Title="Your Apartment" Height="400" Width="600" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="YOUR APARTMENT INFO" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2C3E50" HorizontalAlignment="Center"/>
            
            <Border BorderBrush="#ECF0F1" BorderThickness="1" CornerRadius="5" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Content="Resident Name:" Grid.Row="0" Grid.Column="0" FontWeight="Bold"/>
                    <TextBlock x:Name="tbResidentName" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"/>

                    <Label Content="Apartment No:" Grid.Row="1" Grid.Column="0" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock x:Name="tbApartmentNo" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="10,10,0,0"/>

                    <Label Content="Building Name:" Grid.Row="2" Grid.Column="0" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock x:Name="tbBuildingName" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="10,10,0,0"/>

                    <Label Content="Contract Period:" Grid.Row="3" Grid.Column="0" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock x:Name="tbContractPeriod" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Margin="10,10,0,0"/>
                </Grid>
            </Border>

            <Button Content="Logout" Click="Logout_Click" Width="100" Height="35" Margin="0,30,0,0" Background="#E74C3C" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
