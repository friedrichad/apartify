<Window x:Class="Apartify.Views.staff.RequestDetailsStaff"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Request Details" Height="380" Width="600" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Request Details" FontSize="18" FontWeight="Bold" />

        <StackPanel Grid.Row="1" Margin="0,10,0,0">
            <TextBlock Text="Description" FontWeight="SemiBold" />
            <TextBox x:Name="TxtDescription" TextWrapping="Wrap" Height="80" />

            <WrapPanel Margin="0,8,0,0">
                <StackPanel Width="260">
                    <TextBlock Text="Apartment" FontWeight="SemiBold" />
                    <ComboBox x:Name="CbApartment" IsEnabled="False" DisplayMemberPath="Number" SelectedValuePath="ApartmentId" />

                    <TextBlock Text="Building" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <TextBlock x:Name="TxtBuilding" />
                </StackPanel>

                <StackPanel Width="260" Margin="20,0,0,0">
                    <TextBlock Text="Resident" FontWeight="SemiBold" />
                    <ComboBox x:Name="CbResident" IsEnabled="False" DisplayMemberPath="FullName" SelectedValuePath="ResidentId" />
                    <TextBlock x:Name="TxtResidentContact" />
                </StackPanel>
            </WrapPanel>

            <WrapPanel Margin="0,10,0,0">
                <TextBlock Text="Status:" FontWeight="SemiBold" />
                <TextBlock x:Name="TxtStatus" Margin="6,0,0,0" />

                <TextBlock Text="Request Date:" FontWeight="SemiBold" Margin="20,0,0,0" />
                <DatePicker x:Name="DpRequestDate" IsEnabled="False" Margin="6,0,0,0" />
            </WrapPanel>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
            <Button x:Name="BtnBack" Content="Back" Width="80" Margin="0,0,8,0" />
            <Button x:Name="BtnSave" Content="Save" Width="80" />
        </StackPanel>
    </Grid>
</Window>