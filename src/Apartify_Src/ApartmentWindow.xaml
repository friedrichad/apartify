<Window x:Class="Apartify.Views.ApartmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apartment Management" Height="500" Width="1000">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="0,0,1,0" Padding="10">
            <StackPanel>
                <TextBlock Text="THÔNG TIN CHI TIẾT" FontSize="16" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <Label Content="Số phòng:"/>
                <TextBox Text="{Binding SelectedApartment.Number, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <Label Content="Tầng:"/>
                <TextBox Text="{Binding SelectedApartment.Floor, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <Label Content="Diện tích (m²):"/>
                <TextBox Text="{Binding SelectedApartment.Area, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <Label Content="ID Tòa nhà:"/>
                <TextBox Text="{Binding SelectedApartment.BuildingId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

                <UniformGrid Columns="2" Margin="0,10,0,0">
                    <Button Content="Thêm mới" Command="{Binding AddCommand}" Margin="5" Height="30"/>
                    <Button Content="Lưu thay đổi" Command="{Binding EditCommand}" Margin="5" Height="30" Background="LightBlue"/>
                    <Button Content="Xóa" Command="{Binding DeleteCommand}" Margin="5" Height="30" Background="#e74c3c" Foreground="White"/>
                    <Button Content="Đóng" Command="{Binding CloseCommand}" Margin="5" Height="30"/>
                </UniformGrid>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="10,0,0,0">
            <DataGrid x:Name="dgApartments" 
                      ItemsSource="{Binding Apartments}" 
                      SelectedItem="{Binding SelectedApartment}"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Số Phòng" Binding="{Binding Number}" Width="80"/>
                    <DataGridTextColumn Header="Tầng" Binding="{Binding Floor}" Width="60"/>
                    <DataGridTextColumn Header="Diện Tích" Binding="{Binding Area}" Width="80"/>
                    <DataGridTextColumn Header="Tòa Nhà" Binding="{Binding Building.Name}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>