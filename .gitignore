## Standard Visual Studio .gitignore for .NET Core / .NET 5+

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][In][32]/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# .fake (Visual Studio 2017+)
.fake/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml
nunit-agent.log

# JetBrains Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Visual Studio Code
.vscode/

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# Includes target/ folder for Java/Maven/Gradle
[Tt]arget/
# Old-style NuGet packages folder
packages/

# Entity Framework Core
# Generated by dotnet user-secrets
secrets.json

# Local Config files
appsettings.Development.json
appsettings.Local.json

# Backup & report files from converting an old project file
# to a newer Visual Studio version. Inspect them if you are
# not sure whether they should be ignored or not.
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
ServiceFabricBackup/
*.rptproj.bak

# Others
/temp
/tmp
/move_log.txt
/move_files.bat
/move_log.txt.bak

# Allow .slnx files (New Visual Studio Solution format)
!*.slnx
